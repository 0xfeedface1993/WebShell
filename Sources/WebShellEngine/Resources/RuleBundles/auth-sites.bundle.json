            "expectedValues": null
          }
        ],
        "materialKeys": [
          "username",
          "password",
          "captcha"
        ],
        "accountIDTemplate": null
      },
      "metadata": {
        "site": "jkpan.com",
        "kind": "verified-auth-site",
        "legacyFlow": "LoginByFormhashAndCode + LoginVerifyCode",
        "source": "captcha login shape verified from public article"
      }
    },
    {
      "id": "116pan-vip",
      "providerFamily": "116pan-vip",
      "matchers": [
        {
          "hosts": [
            "www.116pan.xyz",
            "116pan.xyz",
            "www.116pan.com",
            "116pan.com"
          ],
          "hostSuffixes": [],
          "pathPattern": "/f/[A-Za-z0-9]+$"
        }
      ],
      "accountScope": "providerFamily",
      "downloadWorkflowID": "116pan.vip.generateDownload",
      "authWorkflowID": "116pan.vip.captcha.auth",
