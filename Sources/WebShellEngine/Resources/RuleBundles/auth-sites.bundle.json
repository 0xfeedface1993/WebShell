        ],
        "accountIDTemplate": null,
        "captchaRetryPolicy": {
          "mode": "refreshCaptcha",
          "maxAttempts": 50,
          "startAtOutput": "captchaImage"
        }
      },
      "metadata": {
        "site": "116pan.xyz",
        "kind": "verified-auth-site",
        "legacyFlow": "Laravel/Inertia captcha login + VIP generate-download",
        "source": "verified against https://www.116pan.xyz/f/0V02j0lxvpSl on 2026-04-11"
      }
    },
    {
      "id": "koolaayun-vip",
      "providerFamily": "koolaayun-vip",
      "matchers": [
        {
          "hosts": [
            "koolaayun.com",
            "www.koolaayun.com"
          ],
          "hostSuffixes": [],
          "pathPattern": "/[A-Za-z0-9]+/[^/]+\\.zip$"
        }
      ],
      "accountScope": "providerFamily",
      "downloadWorkflowID": "koolaayun.vip.ptRedirectDownload",
      "authWorkflowID": "koolaayun.account.form.auth",
      "authPolicy": {
        "requiresAuthentication": true,
        "expireConditions": [
