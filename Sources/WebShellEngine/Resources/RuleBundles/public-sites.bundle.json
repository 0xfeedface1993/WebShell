    {
      "description": "Fetch tower JS, derive the cookie update URL, populate transient cookies, call ajax.php with load_down_addr1, emit dl.php request.",
      "id": "generic.tower.loadDownAddr1.dlphp",
      "steps": [
        {
          "invokeCapability": {
