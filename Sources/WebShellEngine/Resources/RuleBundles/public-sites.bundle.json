        },
        {
          "http": {
            "attachAuthSession": true,
            "bodyTemplate": "{{ajaxBody}}",
            "headers": {
              "Accept": "text/plain, */*; q=0.01",
              "Accept-Language": "zh-CN,zh-Hans;q=0.9",
              "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
              "Origin": "{{pageOrigin}}",
              "Referer": "{{pageOrigin}}",
              "User-Agent": "WebShellRuleEngine/1.0",
              "X-Requested-With": "XMLHttpRequest"
            },
            "method": "POST",
            "output": "ajaxResponse",
            "persistResponseCookies": false,
            "urlTemplate": "{{pageOrigin}}/ajax.php"
          },
          "type": "http"
        },
        {
          "extract": {
            "group": 0,
            "kind": "regexFirst",
            "pattern": "https?://[^\\s]+/dl\\w*\\.php\\?[^\\\"]+",
            "source": "ajaxResponse.body",
            "target": "downloadURL"
          },
          "type": "extract"
        },
        {
          "emitRequest": {
            "attachAuthSession": false,
            "filenameHints": {
              "directType": "dl.php",
              "resolverFamily": "tower_load_down_addr1"
            },
            "headers": {
              "Referer": "{{pageOrigin}}",
              "User-Agent": "WebShellRuleEngine/1.0"
            },
            "method": "GET",
            "retryHints": {
              "backoffSeconds": 1,
              "maxAttempts": 2,
              "retryableStatusCodes": [
                429,
                503
              ]
            },
            "urlTemplate": "{{downloadURL}}"
          },
          "type": "emitRequest"
        }
      ]
    }
  ],
  "capabilityRefs": [
    {
      "name": "extract.regexLinks",
      "required": true
    },
    {
      "name": "string.asciiHexMD5",
      "required": true
    },
    {
      "name": "url.origin",
      "required": true
    },
    {
      "name": "rosefile.appendDownPath",
      "required": true
    }
  ]
}
