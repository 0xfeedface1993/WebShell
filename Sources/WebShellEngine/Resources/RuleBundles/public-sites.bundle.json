            },
            "method": "GET",
            "output": "jsResponse",
            "persistResponseCookies": true,
            "urlTemplate": "{{jsURL}}"
          },
          "type": "http"
        },
        {
          "extract": {
            "group": 1,
            "kind": "regexFirst",
            "pattern": "\\\"([^\\?\\\"]+\\?type=\\w+&key=)\\\"",
            "source": "jsResponse.body",
            "target": "towerPrefix"
          },
          "type": "extract"
        },
        {
          "extract": {
            "group": 1,
