            "target": "towerRawValue"
          },
          "type": "extract"
        },
        {
          "invokeCapability": {
            "arguments": {},
            "bindings": {
              "text": "towerRawValue"
            },
            "capability": "string.asciiHexMD5",
            "target": "towerHashedValue"
          },
          "type": "invokeCapability"
        },
        {
          "template": {
            "target": "towerCookieURL",
            "template": "{{pageOrigin}}{{towerPrefix}}{{towerKey}}&value={{towerHashedValue}}"
