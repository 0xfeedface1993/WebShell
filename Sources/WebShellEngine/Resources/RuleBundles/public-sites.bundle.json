    {
      "description": "Append /d, fetch the intermediate page, extract direct links, emit the first usable URL.",
      "id": "rosefile.download",
      "steps": [
        {
          "invokeCapability": {
            "arguments": {},
            "bindings": {
              "sourceURL": "input.sourceURL"
            },
            "capability": "rosefile.appendDownPath",
            "target": "roseDownURL"
          },
          "type": "invokeCapability"
        },
        {
          "http": {
            "attachAuthSession": false,
            "headers": {
              "Referer": "{{input.sourceURL}}"
            },
            "method": "GET",
            "output": "rosePage",
            "persistResponseCookies": false,
            "urlTemplate": "{{roseDownURL}}"
          },
          "type": "http"
        },
        {
          "invokeCapability": {
            "arguments": {},
            "bindings": {
              "html": "rosePage.body"
            },
            "capability": "extract.regexLinks",
            "target": "roseLinks"
          },
          "type": "invokeCapability"
        },
        {
          "emitRequest": {
            "attachAuthSession": false,
            "filenameHints": {
              "provider": "rosefile"
            },
            "headers": {
              "Referer": "{{input.sourceURL}}"
            },
            "method": "GET",
            "retryHints": {
              "backoffSeconds": 1,
              "maxAttempts": 2,
              "retryableStatusCodes": [
                429,
                503
              ]
            },
            "urlTemplate": "{{roseLinks.0}}"
          },
          "type": "emitRequest"
        }
      ]
    },
    {
      "description": "Extract fileid from /file-<id>.html, call ajax.php with load_down_addr1, emit dl.php request.",
      "id": "generic.loadDownAddr1.dlphp",
      "steps": [
        {
          "invokeCapability": {
            "arguments": {},
            "bindings": {
              "sourceURL": "input.sourceURL"
            },
            "capability": "url.origin",
            "target": "pageOrigin"
          },
          "type": "invokeCapability"
        },
        {
          "extract": {
            "kind": "urlPath",
            "source": "input.sourceURL",
            "target": "sourcePath"
          },
          "type": "extract"
        },
        {
          "extract": {
            "group": 1,
            "kind": "regexFirst",
            "pattern": "-([\\w\\d]+)\\.\\w+$",
            "source": "sourcePath",
            "target": "fileID"
          },
          "type": "extract"
        },
        {
          "template": {
            "target": "ajaxBody",
            "template": "action=load_down_addr1&file_id={{fileID}}"
          },
          "type": "template"
        },
        {
          "http": {
            "attachAuthSession": false,
            "bodyTemplate": "{{ajaxBody}}",
            "headers": {
              "Accept": "text/plain, */*; q=0.01",
              "Accept-Language": "zh-CN,zh-Hans;q=0.9",
              "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
              "Origin": "{{pageOrigin}}",
              "Referer": "{{input.sourceURL}}",
              "User-Agent": "WebShellRuleEngine/1.0",
              "X-Requested-With": "XMLHttpRequest"
            },
            "method": "POST",
            "output": "ajaxResponse",
            "persistResponseCookies": false,
            "urlTemplate": "{{pageOrigin}}/ajax.php"
          },
          "type": "http"
        },
        {
          "extract": {
            "group": 0,
            "kind": "regexFirst",
            "pattern": "https?://[^\\s]+/dl\\w*\\.php\\?[^\\\"]+",
            "source": "ajaxResponse.body",
            "target": "downloadURL"
          },
          "type": "extract"
        },
        {
          "emitRequest": {
            "attachAuthSession": false,
            "filenameHints": {
              "directType": "dl.php",
              "resolverFamily": "load_down_addr1"
            },
            "headers": {
              "Referer": "{{pageOrigin}}",
              "User-Agent": "WebShellRuleEngine/1.0"
            },
            "method": "GET",
            "retryHints": {
              "backoffSeconds": 1,
              "maxAttempts": 2,
              "retryableStatusCodes": [
                429,
                503
              ]
            },
            "urlTemplate": "{{downloadURL}}"
          },
          "type": "emitRequest"
        }
      ]
    },
